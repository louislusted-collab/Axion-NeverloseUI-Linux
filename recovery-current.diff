+		const char* name = _linux_basename(info->dlpi_name);
+		size_t length = strlen(name);
+		size_t i = 0;
+		for (; i + 1 < ctx->capacity && i < length; ++i)
+			ctx->buffer[i] = static_cast<wchar_t>(static_cast<unsigned char>(name[i]));
+		ctx->buffer[i] = L'\0';
+		return 1;
+	};
